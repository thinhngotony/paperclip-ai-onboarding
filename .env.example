# Copy to .env or let scripts/setup.sh create it.

# vps = detect public IPv4 (or use PAPERCLIP_VPS_HOST / PAPERCLIP_PUBLIC_URL below)
# local = only 127.0.0.1 / localhost (use ./scripts/setup.sh --local)
PAPERCLIP_NETWORK_PROFILE=vps

PAPERCLIP_PORT=3100

# Optional: set if auto-detection is wrong (NAT, multiple IPs). Example: 203.0.113.50
# PAPERCLIP_VPS_HOST=

# Optional: full URL for HTTPS or custom domain (overrides detection). Example:
# PAPERCLIP_PUBLIC_URL=https://paperclip.example.com
# (setup sync will allow that hostname and keep this URL for auth redirects)

# Filled automatically by ./scripts/setup.sh or ./scripts/reapply-vps-env.sh:
# PAPERCLIP_PUBLIC_URL=http://YOUR_PUBLIC_IP:3100
# PAPERCLIP_ALLOWED_HOSTNAMES=127.0.0.1,localhost,YOUR_PUBLIC_IP

PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

BETTER_AUTH_SECRET=
PAPERCLIP_AGENT_JWT_SECRET=

# 9Router on the Docker host (auto-detected by ./scripts/setup.sh and ./scripts/sync-9router-env.sh).
# NINEROUTER_PORT=20128
# NINEROUTER_BIND_HOST=127.0.0.1
# Optional: path to db.json if not ~/.9router/db.json
# NINEROUTER_DB_PATH=/root/.9router/db.json
# Optional: dashboard API key (otherwise read from db.json apiKeys[] or use placeholder)
# NINEROUTER_API_KEY=

OPENAI_BASE_URL=http://127.0.0.1:20128/v1
OPENAI_API_KEY=9router-local

# ANTHROPIC_* NOT SET BY DEFAULT
# Claude Local adapter has issues with 9Router model prefixes (expects "claude-sonnet-4-6" but 9Router has "gh/claude-sonnet-4-6")
# SOLUTION: Use Codex Local or OpenCode Local adapter in Paperclip UI instead
#
# If you need Claude Local adapter:
# 1. Use direct Anthropic API: ANTHROPIC_API_KEY=sk-ant-... + ANTHROPIC_BASE_URL=https://api.anthropic.com
# 2. OR run: pnpm claude login (in vendor/paperclip directory)
# 3. OR configure 9Router with unprefixed Claude models
#
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-api03-...
