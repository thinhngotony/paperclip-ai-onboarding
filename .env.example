# Copy to .env (or let scripts/setup.sh create it).
# Paperclip UI and auth redirects — localhost only (no public domain).
PAPERCLIP_PORT=3100
PAPERCLIP_PUBLIC_URL=http://127.0.0.1:3100
PAPERCLIP_ALLOWED_HOSTNAMES=127.0.0.1,localhost

PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# Required. Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Agent JWT — generate on first install if empty
PAPERCLIP_AGENT_JWT_SECRET=

# 9Router on the Docker host (Paperclip container uses host.docker.internal).
NINEROUTER_PORT=20128
OPENAI_BASE_URL=http://host.docker.internal:20128/v1
ANTHROPIC_BASE_URL=http://host.docker.internal:20128/v1
# Placeholder accepted when 9Router has REQUIRE_API_KEY=false; replace with dashboard key if needed.
OPENAI_API_KEY=9router-local
ANTHROPIC_API_KEY=9router-local
